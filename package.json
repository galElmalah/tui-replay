{
  "name": "tui-replay",
  "version": "0.3.0",
  "description": "Web, terminal, GIF, and video replay viewer for @microsoft/tui-test traces.",
  "keywords": [
    "tui",
    "terminal",
    "replay",
    "trace",
    "tui-test",
    "gif",
    "video"
  ],
  "homepage": "https://github.com/galElmalah/tui-replay#readme",
  "bugs": {
    "url": "https://github.com/galElmalah/tui-replay/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/galElmalah/tui-replay.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sdk": {
      "types": "./dist/sdk.d.ts",
      "import": "./dist/sdk.js"
    },
    "./gif": {
      "types": "./dist/gif/export.d.ts",
      "import": "./dist/gif/export.js"
    },
    "./video": {
      "types": "./dist/video/export.d.ts",
      "import": "./dist/video/export.js"
    }
  },
  "bin": {
    "tui-replay": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs/screenshots",
    "README.md",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test \"dist/**/*.test.js\"",
    "preview": "npm run build && node dist/cli.js preview",
    "gif": "npm run build && node dist/cli.js gif",
    "video": "npm run build && node dist/cli.js video",
    "tui": "npm run build && node dist/cli.js tui"
  },
  "dependencies": {
    "@opentui/core": "^0.2.15",
    "@resvg/resvg-js": "^2.6.2",
    "@xterm/headless": "^6.0.0",
    "commander": "^14.0.2",
    "gifenc": "^1.0.3",
    "open": "^10.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
